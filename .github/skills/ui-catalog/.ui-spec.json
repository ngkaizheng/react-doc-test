[
  {
    "name": "Button",
    "description": "Global uniform brand button, supports loading state and 3 colors.",
    "examples": [
      "<Button variant=\"primary\" isLoading={formSubmitting} type=\"submit\">Submit</Button>",
      "<Button variant=\"secondary\" onClick={handleCancel}>Cancel</Button>\n"
    ],
    "props": [
      {
        "name": "variant",
        "type": "\"primary\" | \"secondary\" | \"danger\" | undefined",
        "required": false,
        "description": "Button color theme"
      },
      {
        "name": "size",
        "type": "\"sm\" | \"md\" | \"lg\" | undefined",
        "required": false,
        "description": ""
      },
      {
        "name": "isLoading",
        "type": "boolean | undefined",
        "required": false,
        "description": "Show loading spinner"
      }
    ]
  },
